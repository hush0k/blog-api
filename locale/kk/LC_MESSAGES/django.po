#: apps/blog/serializers.py:51
msgid "Title cannot be empty."
msgstr "Тақырып бос болмауы керек."

#: apps/blog/serializers.py:82
msgid "Comment serializer rejected empty body"
msgstr "Түсініктеме сериялағышы бос мәтінді қабылдамады"

#: apps/blog/serializers.py:83
msgid "Comment body cannot be empty."
msgstr "Пікір мәтіні бос болмауы керек."

#: apps/users/models.py:14
msgid "The Email field must be set"
msgstr "Электрондық пошта өрісі орнатылуы керек"

#: apps/users/models.py:16
msgid "The Password field must be set"
msgstr "Құпия сөз өрісі орнатылуы керек"

#: apps/users/models.py:31
msgid "Superuser must have is_staff=True."
msgstr "Superuser is_staff=True болуы керек."

#: apps/users/models.py:33
msgid "Superuser must have is_superuser=True."
msgstr "Superuser болуы керек is_superuser=True."

#: apps/users/serializers.py:38
msgid "Passwords do not match."
msgstr "Құпия сөздер сәйкес келмейді."

#: apps/users/serializers.py:63
msgid "Language not supported."
msgstr "Тілге қолдау көрсетілмейді."

#: apps/users/serializers.py:75
msgid "Invalid timezone. Use valid IANA timezone"
msgstr "Уақыт белдеуі жарамсыз. Жарамды IANA уақыт белдеуін пайдаланыңыз"
